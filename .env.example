# ─── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here   # Server-side ONLY — never expose to client

# ─── Google Gemini ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...   # The $9/month recurring price ID

# ─── Google Places (contractor lookup) ─────────────────────────
GOOGLE_PLACES_API_KEY=your-places-api-key-here

# ─── App ───────────────────────────────────────────────────────
APP_URL=https://rootstockapp.com   # Use http://localhost:8888 for local dev
